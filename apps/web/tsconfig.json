{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": "../..",
    "paths": {
      "@html2pdf-pro/config": ["packages/config/src/index.ts"],
      "@html2pdf-pro/database": ["packages/database/src/index.ts"],
      "@html2pdf-pro/teaching-engine": ["packages/teaching-engine/src/index.ts"],
      "@html2pdf-pro/web/*": ["apps/web/src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "../../packages/teaching-engine/src/**/*.ts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
